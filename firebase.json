{
  "hosting": [
    {
      "target": "review",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        "docs/**",
        "scripts/**",
        "tests/**",
        "test-results/**",
        "playwright-report/**",
        "node_modules/**",
        "functions/**",
        "secrets/**",
        "package.json",
        "package-lock.json",
        "eslint.config.js",
        "playwright.config.cjs",
        "README.md"
      ],
      "cleanUrls": true,
      "trailingSlash": false
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ]
}
